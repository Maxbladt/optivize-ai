        body {
            font-family: "Open Sans", Verdana, Arial;
            margin: 0px;
            font-weight: normal;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            min-height: 100vh;
            display: -webkit-box;
            display: -ms-flexbox;
            display: flex;
            -webkit-box-align: center;
            -ms-flex-align: center;
            align-items: center;
            -webkit-box-pack: center;
            -ms-flex-pack: center;
            justify-content: center;
        }

        .wrapper {
            width: 420px;
            margin: 0 auto;
            padding: 80px 30px;
            text-align: center;
        }

        .error-code {
            font-size: 10;
            font-size: 100px;
            font-family: "Cera";
            line-height: 1;
        }

        .error-message,
        .error-actions,
        .error-code {
            padding: 20px 0;
        }

        .error-message {
            font-size: 16px;
            line-height: 28px;
        }

        h2 {
            margin-top: 0;
        }

        .button {
            line-height: 40px;
            background: black;
            line-height: 40px;
            display: -webkit-inline-box;
            display: -ms-inline-flexbox;
            display: inline-flex;
            color: white;
            padding: 0 20px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
        }

        .header{
            height: 10vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .desktop-logo {
            width: 130px;
            height: 22px;
            fill:black;
        }
