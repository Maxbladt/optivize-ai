<script type="text/javascript" src="https://sanday.com/wp-content/uploads/fusion-scripts/6bdcaa6f834d6140618c09e1a07a87f6.min.js?ver=3.15.2" id="fusion-scripts-js" data-rocket-defer defer></script>
<script type="rocketlazyloadscript">
document.addEventListener('DOMContentLoaded', function() {

    var itemsToTrack = [
        {
            id: 'menu-item-698',
            virtualUrl: '/selfservice-portaal'
        },
        {
            id: 'menu-item-393',
            virtualUrl: '/teamviewer'
        }
    ];

    itemsToTrack.forEach(function(item) {
        var menuItem = document.getElementById(item.id);
        if (!menuItem) return;

        var link = menuItem.querySelector('a');
        if (!link) return;

        link.addEventListener('click', function() {
            if (window.leadinfo) {
                window.leadinfo('setCustomUrl', item.virtualUrl);
                window.leadinfo('trackPageView');
            }
        });
    });

});
</script>		</div>

			</body>
</html>

